{
  "apps": [
    {
      "name": "crypto_bot_system",
      "script": "main.py",
      "interpreter": "python3",
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 5000,
      "log_date_format": "YYYY-MM-DD HH:mm:Z",
      "error_file": "logs/pm2_error.log",
      "out_file": "logs/pm2_out.log",
      "merge_logs": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
